<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Varliet — FinTech Growth Strategist | Behavioral Revenue Systems</title>
<meta name="description" content="I don't help FinTechs get users. I help them turn users into consistent revenue. The Behavioral Revenue System™ — 90-day implementation." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&display=swap" rel="stylesheet">
<style>
  :root, [data-theme="dark"]{
    --orange:#ffa62e;
    --orange-glow:#ffb347;
    --blue-soft:#b3d2ff;
    --blue-sparkle:#cfe1ff;
    --navy:#05294e;
    --navy-deep:#03182e;
    --navy-mid:#0a3a6b;
    --white:#ffffff;
    --ink:#eaf1fb;
    --ink-soft:#c4d3e6;
    --muted:#9bb0cc;
    --line:rgba(179,210,255,.14);
    --line-strong:rgba(179,210,255,.25);
    --bg-soft:#0a3158;
    --maxw:1240px;
    --nav-bg:rgba(5,41,78,.78);
    --card-bg:rgba(179,210,255,.05);
    --card-bg-soft:rgba(179,210,255,.04);
    --heading:#ffffff;
    --thumb-haoma-from:#0a3a6b; --thumb-haoma-to:#1a5cb0;
    --thumb-ba-from:#b3d2ff;   --thumb-ba-to:#7aa8e0;
    --thumb-family-from:#03182e; --thumb-family-to:#3a4a6e;
  }
  [data-theme="light"]{
    --orange:#ff8a00;
    --orange-glow:#ffa62e;
    --blue-soft:#5a8fd6;
    --blue-sparkle:#0a3a6b;
    --navy:#f6f9ff;          /* main background */
    --navy-deep:#eaf1fb;     /* deeper sections */
    --navy-mid:#dbe7f7;
    --white:#05294e;
    --ink:#0a2540;           /* body text */
    --ink-soft:#3d567a;
    --muted:#6b7d99;
    --line:rgba(5,41,78,.10);
    --line-strong:rgba(5,41,78,.20);
    --bg-soft:#dbe7f7;
    --nav-bg:rgba(246,249,255,.85);
    --card-bg:rgba(5,41,78,.04);
    --card-bg-soft:rgba(5,41,78,.025);
    --heading:#05294e;
    --thumb-haoma-from:#5a8fd6; --thumb-haoma-to:#0a3a6b;
    --thumb-ba-from:#cfe1ff;   --thumb-ba-to:#7aa8e0;
    --thumb-family-from:#0a3a6b; --thumb-family-to:#5a8fd6;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;color:var(--ink);background:var(--navy);line-height:1.65;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s}
  ::selection{background:var(--orange);color:#fff}
  h1,h2,h3,h4{font-family:'Fraunces',Georgia,serif;font-weight:600;line-height:1.1;letter-spacing:-0.02em;color:var(--heading)}
  h1{font-size:clamp(2.4rem,5.5vw,4.8rem);font-weight:700}
  h2{font-size:clamp(1.9rem,3.8vw,3.2rem)}
  h3{font-size:clamp(1.4rem,2.4vw,2rem)}
  p{color:var(--ink-soft);font-size:1.05rem}
  .container{max-width:var(--maxw);margin:0 auto;padding:0 32px}
  .eyebrow{display:inline-block;font-size:.78rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--orange);padding:6px 14px;border:1px solid var(--line-strong);border-radius:99px;background:rgba(179,210,255,.06)}
  .accent{color:var(--orange);text-shadow:0 0 24px rgba(255,166,46,.45)}
  .sparkle{color:var(--blue-sparkle)}
  nav{position:sticky;top:0;z-index:50;background:var(--nav-bg);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 32px;max-width:var(--maxw);margin:0 auto;gap:24px}
  .logo{font-family:'Fraunces',serif;font-weight:700;font-size:1.5rem;color:var(--heading);text-decoration:none;letter-spacing:-.02em}
  .logo span{color:var(--orange)}
  .nav-links{display:flex;gap:28px;align-items:center}
  .nav-links a{color:var(--ink-soft);text-decoration:none;font-weight:500;font-size:.92rem;transition:color .2s;white-space:nowrap}
  .nav-links a:hover{color:var(--orange)}
  .nav-tools{display:flex;align-items:center;gap:10px}
  .theme-toggle{background:transparent;border:1px solid var(--line-strong);color:var(--ink);width:38px;height:38px;border-radius:99px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:all .2s;padding:0;font-size:1rem;line-height:1}
  .theme-toggle:hover{border-color:var(--orange);color:var(--orange)}
  .theme-toggle .icon-sun{display:none}
  [data-theme="light"] .theme-toggle .icon-moon{display:none}
  [data-theme="light"] .theme-toggle .icon-sun{display:inline}
  .menu-btn{display:none;background:transparent;border:1px solid var(--line-strong);color:var(--ink);width:42px;height:42px;border-radius:8px;cursor:pointer;font-size:1.2rem;align-items:center;justify-content:center;padding:0}
  .mobile-menu{display:none;position:fixed;inset:0;z-index:60;background:var(--navy-deep);padding:80px 32px;overflow-y:auto}
  .mobile-menu.open{display:flex;flex-direction:column;gap:20px}
  .mobile-menu a{color:var(--ink);text-decoration:none;font-size:1.4rem;font-family:'Fraunces',serif;padding:14px 0;border-bottom:1px solid var(--line)}
  .mobile-menu .close{position:absolute;top:24px;right:24px;background:transparent;border:1px solid var(--line-strong);color:var(--ink);width:42px;height:42px;border-radius:8px;font-size:1.4rem;cursor:pointer}
  .btn{display:inline-block;padding:15px 28px;border-radius:8px;font-weight:600;font-size:.95rem;text-decoration:none;transition:all .25s ease;cursor:pointer;border:none;font-family:inherit}
  .btn-primary{background:var(--orange);color:#05294e;box-shadow:0 8px 24px -8px rgba(255,166,46,.5)}
  .btn-primary:hover{background:var(--orange-glow);transform:translateY(-2px);box-shadow:0 0 32px 4px rgba(255,166,46,.45),0 12px 28px -10px rgba(255,166,46,.6)}
  .btn-secondary{background:transparent;color:var(--heading);border:1.5px solid var(--blue-soft)}
  .btn-secondary:hover{background:var(--blue-soft);color:#05294e}
  .btn-orange{background:var(--orange);color:#05294e}
  .btn-orange:hover{background:var(--heading);color:var(--navy)}
  section{padding:130px 0}
  .hero{background:radial-gradient(ellipse 90% 70% at 80% 20%,rgba(255,166,46,.18),transparent 60%),radial-gradient(ellipse 80% 60% at 10% 90%,rgba(179,210,255,.16),transparent 60%),var(--navy);padding:140px 0 150px;position:relative;overflow:hidden}
  .hero::before{content:"";position:absolute;top:-150px;right:-150px;width:600px;height:600px;background:radial-gradient(circle,rgba(255,166,46,.22) 0%,transparent 65%);filter:blur(20px)}
  .hero::after{content:"";position:absolute;bottom:-200px;left:-150px;width:550px;height:550px;background:radial-gradient(circle,rgba(179,210,255,.18) 0%,transparent 65%);filter:blur(20px)}
  .hero-inner{position:relative;z-index:1;max-width:1080px}
  .hero h1{margin:24px 0 28px}
  .hero p.sub{font-size:1.3rem;max-width:780px;margin-bottom:44px;color:var(--ink-soft)}
  .cta-row{display:flex;gap:16px;flex-wrap:wrap}
  .section-head{max-width:880px;margin-bottom:64px}
  .section-head .eyebrow{margin-bottom:20px}
  .section-head h2{margin-bottom:22px}
  .problem{background:var(--navy-deep);position:relative;overflow:hidden}
  .problem::before{content:"";position:absolute;top:50%;right:-200px;width:500px;height:500px;background:radial-gradient(circle,rgba(255,166,46,.12),transparent 70%);transform:translateY(-50%)}
  .problem-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:48px;position:relative;z-index:1}
  .problem-card{padding:32px;border:1px solid var(--line);border-radius:14px;background:rgba(179,210,255,.04);transition:all .3s;backdrop-filter:blur(6px)}
  .problem-card:hover{border-color:rgba(255,166,46,.4);transform:translateY(-4px);background:rgba(255,166,46,.06)}
  .problem-card .num{color:var(--orange);font-family:'Fraunces',serif;font-size:1.7rem;font-weight:700;margin-bottom:10px;display:block;text-shadow:0 0 20px rgba(255,166,46,.4)}
  .problem-card p{color:var(--ink-soft);font-size:.98rem}
  .shift{background:var(--navy-deep)}
  .shift-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:80px;align-items:start}
  .shift-grid .col-text p{margin-bottom:18px;font-size:1.1rem}
  .shift-list{display:flex;flex-direction:column;gap:14px}
  .shift-list div{display:flex;gap:14px;align-items:flex-start;padding:22px;background:rgba(179,210,255,.05);border-radius:12px;border:1px solid var(--line)}
  .shift-list div::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--orange);margin-top:9px;flex-shrink:0;box-shadow:0 0 12px rgba(255,166,46,.7)}
  .shift-list div span{color:var(--heading);font-weight:500}
  .pos{background:var(--navy)}
  .pos h2 em{font-style:normal;color:var(--orange);font-family:inherit}
  .pos-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:48px}
  .pos-card{padding:34px;border:1px solid var(--line);border-radius:14px;transition:all .3s;background:rgba(179,210,255,.04)}
  .pos-card:hover{border-color:var(--orange);transform:translateY(-6px);box-shadow:0 30px 60px -30px rgba(255,166,46,.4),0 0 0 1px rgba(255,166,46,.2)}
  .pos-card .ico{width:46px;height:46px;border-radius:10px;background:linear-gradient(135deg,var(--orange),var(--orange-glow));display:flex;align-items:center;justify-content:center;color:var(--navy);font-weight:700;margin-bottom:20px;font-family:'Fraunces',serif;box-shadow:0 0 20px rgba(255,166,46,.4)}
  .pos-card h4{font-size:1.15rem;margin-bottom:10px}
  .pos-card p{font-size:.95rem}
  .mech{background:linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 100%);position:relative;overflow:hidden}
  .mech::before{content:"";position:absolute;bottom:-200px;left:-150px;width:500px;height:500px;background:radial-gradient(circle,rgba(255,166,46,.18) 0%,transparent 70%);filter:blur(20px)}
  .mech::after{content:"";position:absolute;top:-100px;right:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(179,210,255,.15),transparent 70%);filter:blur(20px)}
  .mech-content{position:relative;z-index:1}
  .mech-pipe{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:48px}
  .mech-pipe .step{padding:28px;background:rgba(179,210,255,.06);border:1px solid var(--line-strong);border-radius:12px;transition:all .3s}
  .mech-pipe .step:hover{border-color:var(--orange);background:rgba(255,166,46,.06)}
  .mech-pipe .step .arrow{color:var(--orange);font-size:1.5rem;margin-bottom:10px;display:block;text-shadow:0 0 16px rgba(255,166,46,.6)}
  .mech-pipe .step h4{font-size:1.1rem;margin-bottom:8px}
  .mech-pipe .step p{color:var(--ink-soft);font-size:.92rem}
  .promise{background:var(--navy)}
  .promise-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:80px;align-items:center}
  .promise-list{list-style:none;display:flex;flex-direction:column;gap:18px}
  .promise-list li{padding-left:34px;position:relative;font-size:1.08rem;color:var(--heading);font-weight:500}
  .promise-list li::before{content:"→";position:absolute;left:0;top:0;color:var(--orange);font-weight:700;font-size:1.3rem;text-shadow:0 0 12px rgba(255,166,46,.6)}
  .promise-stat{background:linear-gradient(135deg,rgba(255,166,46,.12),rgba(179,210,255,.08));padding:52px;border-radius:18px;border:1px solid var(--line-strong);border-left:4px solid var(--orange);position:relative;overflow:hidden}
  .promise-stat::before{content:"";position:absolute;top:-50px;right:-50px;width:200px;height:200px;background:radial-gradient(circle,rgba(255,166,46,.25),transparent 70%);filter:blur(20px)}
  .promise-stat .big{font-family:'Fraunces',serif;font-size:4.4rem;font-weight:700;color:var(--heading);line-height:1;position:relative;z-index:1}
  .promise-stat p{margin-top:12px;font-size:1.05rem;position:relative;z-index:1}
  .credibility{background:var(--navy-deep);padding:90px 0}
  .proof{background:var(--navy-deep)}
  .flow{display:grid;grid-template-columns:repeat(5,1fr);gap:18px;margin-top:60px}
  .flow-step{background:rgba(179,210,255,.05);padding:30px 24px;border-radius:14px;border:1px solid var(--line);position:relative;transition:all .3s}
  .flow-step:hover{border-color:var(--orange);transform:translateY(-4px);background:rgba(255,166,46,.06)}
  .flow-step .stepnum{font-family:'Fraunces',serif;font-size:.95rem;color:var(--orange);font-weight:700;letter-spacing:.1em}
  .flow-step h4{margin:12px 0 12px;font-size:1.1rem}
  .flow-step p{font-size:.9rem;color:var(--ink-soft);margin-bottom:16px}
  .flow-step .proof-tag{font-size:.78rem;color:var(--navy);padding:6px 12px;background:var(--blue-sparkle);border-radius:6px;display:inline-block;font-weight:600}
  .synthesis{margin-top:90px;text-align:center;max-width:820px;margin-left:auto;margin-right:auto}
  .synthesis h3{margin-bottom:18px}
  .closing-realization{background:linear-gradient(135deg,var(--navy-mid),var(--navy-deep));border:1px solid var(--line-strong);padding:64px;border-radius:18px;margin-top:64px;text-align:center;position:relative;overflow:hidden}
  .closing-realization::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(255,166,46,.15),transparent 60%)}
  .closing-realization h3{margin-bottom:18px;position:relative;z-index:1}
  .closing-realization p{color:var(--ink-soft);font-size:1.1rem;max-width:680px;margin:0 auto;position:relative;z-index:1}
  .projects-preview{background:var(--navy)}
  .projects-preview .head-row{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:56px}
  .proj-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
  .proj-card{border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:all .35s ease;background:rgba(179,210,255,.05);text-decoration:none;color:inherit;display:block}
  .proj-card:hover{transform:translateY(-8px);box-shadow:0 30px 60px -30px rgba(255,166,46,.35),0 0 0 1px rgba(255,166,46,.3);border-color:var(--orange)}
  .proj-thumb{aspect-ratio:16/10;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:.85rem;text-align:center;padding:20px;background-size:cover;background-position:center;position:relative;overflow:hidden}
  #thumb-tourism{background:linear-gradient(135deg,#ffa62e 0%,#ff7a00 100%)}
  #thumb-haoma{background:linear-gradient(135deg,var(--thumb-haoma-from) 0%,var(--thumb-haoma-to) 100%)}
  #thumb-ba{background:linear-gradient(135deg,var(--thumb-ba-from) 0%,var(--thumb-ba-to) 100%)}
  #thumb-family{background:linear-gradient(135deg,var(--thumb-family-from) 0%,var(--thumb-family-to) 100%)}
  .proj-thumb .placeholder-tag{background:rgba(255,255,255,.92);color:var(--navy);padding:8px 14px;border-radius:6px;font-weight:600;font-size:.82rem}
  .proj-body{padding:28px}
  .proj-body .tag{font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;color:var(--orange);font-weight:600}
  .proj-body h4{margin:10px 0 12px;font-size:1.3rem}
  .proj-body p{font-size:.95rem;margin-bottom:16px}
  .proj-body .arrow{color:var(--orange);font-weight:600;font-size:.9rem}
  .projects-full{background:var(--navy-deep)}
  .case{background:rgba(179,210,255,.04);border-radius:20px;padding:64px;margin-bottom:48px;border:1px solid var(--line)}
  .case-header{margin-bottom:44px;padding-bottom:32px;border-bottom:1px solid var(--line)}
  .case-header .eyebrow{margin-bottom:18px}
  .case-header h3{margin-bottom:14px}
  .case-header p{color:var(--ink-soft)}
  .case-meta{display:flex;flex-wrap:wrap;gap:28px;margin-top:22px;font-size:.9rem;color:var(--ink-soft)}
  .case-meta strong{color:var(--orange);display:block;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;margin-bottom:4px;font-weight:600}
  .case-grid{display:grid;grid-template-columns:200px 1fr;gap:36px;padding:28px 0;border-bottom:1px solid var(--line)}
  .case-grid:last-of-type{border-bottom:none}
  .case-grid .label{font-size:.78rem;letter-spacing:.15em;text-transform:uppercase;color:var(--orange);font-weight:600;padding-top:6px}
  .case-grid h4{font-size:1.35rem;margin-bottom:14px}
  .case-grid p{margin-bottom:12px;color:var(--ink-soft)}
  .case-grid ul{list-style:none;display:flex;flex-direction:column;gap:9px;margin-top:10px}
  .case-grid ul li{padding-left:22px;position:relative;color:var(--ink-soft);font-size:.98rem}
  .case-grid ul li::before{content:"•";position:absolute;left:6px;color:var(--orange);font-weight:700}
  .media-slot{background:rgba(179,210,255,.04);border:2px dashed rgba(179,210,255,.3);border-radius:12px;aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:.9rem;text-align:center;padding:20px;margin:16px 0;flex-direction:column;gap:6px}
  .metrics-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px;margin-top:18px}
  .metric{padding:22px;background:rgba(255,166,46,.08);border-radius:10px;border-left:3px solid var(--orange)}
  .metric .num{font-family:'Fraunces',serif;font-size:1.9rem;font-weight:700;color:var(--heading);line-height:1}
  .metric .lbl{font-size:.82rem;color:var(--ink-soft);margin-top:6px}
  .fintech-bridge{background:linear-gradient(135deg,rgba(255,166,46,.12),rgba(179,210,255,.08));border:1px solid rgba(255,166,46,.25);padding:36px;border-radius:14px;margin-top:32px}
  .fintech-bridge h4{color:var(--heading)}
  .fintech-bridge p{color:var(--ink-soft)}
  .who{background:var(--navy)}
  .who-grid{display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-top:48px}
  .who-card{padding:40px;border-radius:16px;border:1px solid var(--line)}
  .who-card.fit{background:rgba(255,166,46,.08);border-color:rgba(255,166,46,.3)}
  .who-card.notfit{background:rgba(179,210,255,.04)}
  .who-card h3{margin-bottom:18px;font-size:1.5rem}
  .who-card .badge{display:inline-block;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;padding:6px 14px;border-radius:99px;margin-bottom:16px}
  .who-card.fit .badge{background:var(--orange);color:var(--navy)}
  .who-card.notfit .badge{background:rgba(179,210,255,.15);color:var(--blue-sparkle)}
  .who-card ul{list-style:none;display:flex;flex-direction:column;gap:12px;margin-top:14px}
  .who-card ul li{padding-left:28px;position:relative;color:var(--ink-soft);font-size:1rem}
  .who-card.fit ul li::before{content:"✓";position:absolute;left:0;color:var(--orange);font-weight:700;font-size:1.1rem}
  .who-card.notfit ul li::before{content:"✕";position:absolute;left:0;color:#ff7a8a;font-weight:700;font-size:1.1rem}
  .timeline{background:var(--navy-deep)}
  .timeline-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:56px}
  .tl-step{padding:32px 28px;background:rgba(179,210,255,.05);border:1px solid var(--line);border-radius:14px;position:relative;transition:all .3s}
  .tl-step:hover{border-color:var(--orange);transform:translateY(-4px)}
  .tl-step .weeks{font-size:.78rem;letter-spacing:.15em;text-transform:uppercase;color:var(--orange);font-weight:700}
  .tl-step .num{font-family:'Fraunces',serif;font-size:2.6rem;color:var(--orange);font-weight:700;line-height:1;margin:8px 0;text-shadow:0 0 20px rgba(255,166,46,.3)}
  .tl-step h4{font-size:1.2rem;margin-bottom:12px}
  .tl-step p{font-size:.92rem;margin-bottom:14px;color:var(--ink-soft)}
  .tl-step .outcome{padding:12px 14px;background:rgba(255,166,46,.1);border-radius:8px;font-size:.85rem;color:var(--heading);border-left:2px solid var(--orange)}
  .deliver{background:var(--navy)}
  .deliver-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;margin-top:48px}
  .deliver-card{padding:30px;background:rgba(179,210,255,.05);border:1px solid var(--line);border-radius:14px;transition:all .3s}
  .deliver-card:hover{border-color:var(--orange)}
  .deliver-card .d-num{font-family:'Fraunces',serif;color:var(--orange);font-weight:700;font-size:.9rem;letter-spacing:.1em}
  .deliver-card h4{font-size:1.15rem;margin:8px 0 14px}
  .deliver-card ul{list-style:none;display:flex;flex-direction:column;gap:8px}
  .deliver-card ul li{padding-left:18px;position:relative;color:var(--ink-soft);font-size:.92rem}
  .deliver-card ul li::before{content:"•";position:absolute;left:4px;color:var(--orange)}
